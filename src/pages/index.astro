---
import Layout from '../layouts/Layout.astro';
---

<Layout title="AIFI26 · cronograma">
  <div class="splash">
    <div class="container">
      <h1 class="brand">aifi<span class="accent">/26</span></h1>
      <p class="meta">21 may 2026 · Hotel Hilton Buenos Aires</p>
      <p class="hint" id="hint">Redirigiendo…</p>

      <noscript>
        <p class="hint">
          <a href="/ahora">Ver cronograma →</a>
        </p>
      </noscript>
    </div>
  </div>
</Layout>

<script>
  // Always send users to /ahora (pre-event shows the calendar with a discrete
  // "faltan X días" eyebrow; during the event shows live timeline; post shows archive).
  function redirect() {
    window.location.replace('/ahora');
  }

  document.addEventListener('astro:page-load', redirect);
  redirect();
</script>

<style>
  .splash {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--s-7) var(--s-4);
  }

  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    text-align: center;
  }

  .brand {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--t-3xl);
    letter-spacing: -0.04em;
    line-height: 0.9;
    margin: 0;
    color: var(--fg);
  }

  .brand .accent {
    color: var(--cyan);
  }

  .meta {
    font-family: var(--font-mono);
    font-size: var(--t-sm);
    color: var(--fg-muted);
    margin: var(--s-4) 0 var(--s-7);
    letter-spacing: 0.02em;
  }

  .hint {
    font-size: var(--t-sm);
    color: var(--fg-dim);
  }

  .hint a {
    color: var(--cyan);
  }
</style>
