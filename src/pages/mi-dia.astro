---
import Layout from '../layouts/Layout.astro';
import Ticker from '../components/Ticker.astro';
import ModeToggle from '../components/ModeToggle.astro';
import sesionesData from '../data/sesiones.json';
import speakersData from '../data/speakers.json';
import { SALA_NOMBRE, type Sesion, type Speaker } from '../types';

const sesiones = sesionesData as Sesion[];
const speakers = speakersData as Speaker[];
---

<Layout
  title="Mi día · AIFI26"
  description="Tu agenda personalizada de AIFI26."
>
  <Ticker />
  <ModeToggle active="mi-dia" />

  <div id="import-prompt" class="import-prompt" hidden>
    <div class="container">
      <p class="prompt-title">Estás viendo una agenda compartida.</p>
      <p class="prompt-sub" id="prompt-sub"></p>
      <div class="prompt-actions">
        <button class="btn btn-primary" data-action="replace" type="button">Reemplazar la mía</button>
        <button class="btn" data-action="merge" type="button">Agregar a la mía</button>
        <button class="btn btn-ghost" data-action="cancel" type="button">Cancelar</button>
      </div>
    </div>
  </div>

  <header class="hero">
    <div class="container">
      <p class="eyebrow">jueves 21 mayo · Hilton BA · tu agenda</p>

      <ul class="stats" id="stats" aria-label="Resumen de tu agenda">
        <li class="stat">
          <span class="stat-num" id="stat-count">0</span>
          <span class="stat-label">sesiones</span>
        </li>
        <li class="stat stat-conflict" id="stat-conflict-li" hidden>
          <span class="stat-num" id="stat-conflict">0</span>
          <span class="stat-label">conflictos</span>
        </li>
        <li class="stat">
          <span class="stat-num" id="stat-duration">--</span>
          <span class="stat-label">total</span>
        </li>
        <li class="stat" id="stat-spread-li" hidden>
          <span class="stat-num" id="stat-spread">--</span>
          <span class="stat-label">cubierto</span>
        </li>
      </ul>
    </div>
  </header>

  <section id="empty-state" class="empty-state" hidden>
    <div class="container">
      <div class="empty-art" aria-hidden="true">
        <span class="ea-block ea-1"></span>
        <span class="ea-block ea-2"></span>
        <span class="ea-block ea-3"></span>
      </div>
      <h2 class="empty-title">Tu día está vacío</h2>
      <p class="empty-sub">Andá a Día completo, tocá las charlas que querés ver, y volvé.<br />Detectamos conflictos solos.</p>
      <a class="btn btn-primary" href="/dia">Armar mi día →</a>
    </div>
  </section>

  <section
    id="conflict-section"
    class="conflict-section"
    aria-label="Conflictos a resolver"
    hidden
  >
    <div class="container">
      <header class="cs-head">
        <span class="cs-tag">⚠ decisiones por tomar</span>
        <h2 class="cs-title" id="conflict-title">2 conflictos</h2>
        <p class="cs-sub">Dos charlas se pisan al mismo tiempo. Decidí cuál te quedás.</p>
      </header>
      <div id="conflict-list" class="conflict-list"></div>
    </div>
  </section>

  <section id="calendar-section" class="calendar-section" aria-label="Tu agenda visual" hidden>
    <div class="container">
      <header class="cs-head-mini">
        <h2 class="cs-title-mini">Tu día</h2>
        <p class="cs-hint">tocá un bloque para ver el detalle</p>
      </header>
      <div id="mini-calendar" class="mini-calendar"></div>
    </div>
  </section>

  <section id="actions-bar" class="actions-bar" aria-label="Acciones" hidden>
    <div class="container">
      <button class="btn btn-primary btn-hero" id="ics-btn" type="button">
        <span class="btn-icon" aria-hidden="true">↓</span> Exportar a tu calendario
      </button>
      <p class="actions-hint">Compatible con Google Calendar, Apple, Outlook · descarga un archivo .ics</p>

      <div class="actions-secondary">
        <button class="btn" id="share-btn" type="button">
          <span class="btn-icon" aria-hidden="true">↗</span> Compartir
        </button>
        <button class="btn btn-ghost" id="clear-btn" type="button">
          Vaciar
        </button>
      </div>

      <p class="actions-note" id="actions-status" aria-live="polite"></p>
    </div>
  </section>

  <div id="clear-modal" class="clear-modal" hidden role="dialog" aria-modal="true" aria-labelledby="clear-title">
    <div class="clear-backdrop" data-clear-cancel></div>
    <div class="clear-dialog">
      <h3 id="clear-title" class="clear-h">¿Vaciar tu día?</h3>
      <p class="clear-p" id="clear-msg">Vas a perder las sesiones guardadas.</p>
      <div class="clear-actions">
        <button class="btn btn-ghost" type="button" data-clear-cancel>Cancelar</button>
        <button class="btn btn-danger" type="button" data-clear-confirm>Sí, vaciar</button>
      </div>
    </div>
  </div>

  <script
    is:inline
    define:vars={{
      sesionesData: sesiones,
      speakersData: speakers,
      SALA_NOMBRE_JS: SALA_NOMBRE,
    }}
  >
    const STORAGE_KEY = 'aifi26.favorites';

    function getStored() {
      try {
        return (localStorage.getItem(STORAGE_KEY) ?? '')
          .split(',')
          .map((s) => s.trim())
          .filter(Boolean);
      } catch {
        return [];
      }
    }

    function setStored(ids) {
      try {
        localStorage.setItem(STORAGE_KEY, ids.join(','));
      } catch {
        /* private mode */
      }
    }

    function getValidIds() {
      return new Set(sesionesData.map((s) => s.id));
    }

    function filterValid(ids) {
      const valid = getValidIds();
      return Array.from(new Set(ids.filter((id) => valid.has(id))));
    }

    function getQueryFavorites() {
      const params = new URLSearchParams(window.location.search);
      const raw = params.get('s');
      if (!raw) return null;
      return filterValid(raw.split(',').map((x) => x.trim()).filter(Boolean));
    }

    function favSesiones(ids) {
      return ids
        .map((id) => sesionesData.find((s) => s.id === id))
        .filter(Boolean)
        .sort((a, b) => new Date(a.inicio).getTime() - new Date(b.inicio).getTime());
    }

    function hasOverlap(a, b) {
      return new Date(a.inicio).getTime() < new Date(b.fin).getTime() &&
        new Date(b.inicio).getTime() < new Date(a.fin).getTime();
    }

    function findConflictPairs(list) {
      const pairs = [];
      for (let i = 0; i < list.length; i++) {
        for (let j = i + 1; j < list.length; j++) {
          const a = list[i];
          const b = list[j];
          if (a.sala === b.sala) continue;
          if (new Date(b.inicio).getTime() >= new Date(a.fin).getTime()) break;
          if (hasOverlap(a, b)) pairs.push([a, b]);
        }
      }
      return pairs;
    }

    function durationMin(s) {
      return Math.round((new Date(s.fin).getTime() - new Date(s.inicio).getTime()) / 60_000);
    }

    function fmtDuration(min) {
      if (min < 60) return `${min}m`;
      const h = Math.floor(min / 60);
      const m = min % 60;
      return m === 0 ? `${h}h` : `${h}h ${m}m`;
    }

    function fmtRange(a, b) {
      return `${a.slice(11, 16)}–${b.slice(11, 16)}`;
    }

    function escapeHtml(s) {
      return String(s)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function speakersInline(sesion, max = 2) {
      const byId = new Map(speakersData.map((s) => [s.id, s]));
      const names = sesion.speakers
        .map((id) => byId.get(id))
        .filter(Boolean)
        .map((sp) => sp.nombre);
      if (names.length === 0) return '';
      if (names.length <= max) return names.join(' · ');
      return `${names.slice(0, max).join(' · ')} +${names.length - max}`;
    }

    function renderStats(list, pairs) {
      const count = list.length;
      const totalMin = list.reduce((acc, s) => acc + durationMin(s), 0);
      const spread = count > 0 ? fmtRange(list[0].inicio, list[list.length - 1].fin) : '--';

      document.getElementById('stat-count').textContent = String(count);
      document.getElementById('stat-duration').textContent = count > 0 ? fmtDuration(totalMin) : '--';

      const spreadLi = document.getElementById('stat-spread-li');
      const spreadEl = document.getElementById('stat-spread');
      if (count > 0) {
        spreadEl.textContent = spread;
        spreadLi.hidden = false;
      } else {
        spreadLi.hidden = true;
      }

      const conflictLi = document.getElementById('stat-conflict-li');
      const conflictEl = document.getElementById('stat-conflict');
      if (pairs.length > 0) {
        conflictEl.textContent = String(pairs.length);
        conflictLi.hidden = false;
      } else {
        conflictLi.hidden = true;
      }
    }

    function renderConflictSection(pairs) {
      const section = document.getElementById('conflict-section');
      const title = document.getElementById('conflict-title');
      const list = document.getElementById('conflict-list');
      if (!section || !list || !title) return;

      if (pairs.length === 0) {
        section.hidden = true;
        return;
      }

      section.hidden = false;
      title.textContent = `${pairs.length} ${pairs.length === 1 ? 'conflicto' : 'conflictos'}`;
      list.innerHTML = '';

      pairs.forEach((pair) => {
        const [a, b] = pair;
        const wrap = document.createElement('div');
        wrap.className = 'conflict-pair';
        wrap.innerHTML = `
          <div class="cp-time">${escapeHtml(fmtRange(a.inicio, a.fin))} vs ${escapeHtml(fmtRange(b.inicio, b.fin))}</div>
          <div class="cp-grid">
            ${renderConflictCard(a)}
            <div class="cp-vs" aria-hidden="true"><span>vs</span></div>
            ${renderConflictCard(b)}
          </div>
        `;
        list.appendChild(wrap);
      });

      list.querySelectorAll('[data-keep]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const keep = btn.dataset.keep;
          const drop = btn.dataset.drop;
          if (!keep || !drop) return;
          const next = getStored().filter((x) => x !== drop);
          setStored(next);
          renderAll(next);
        });
      });
    }

    function renderConflictCard(s) {
      const speakers = speakersInline(s, 2);
      const otherId = s.id;
      return `
        <article class="cp-card sala-${s.sala}">
          <header class="cpc-head">
            <span class="cpc-sala">${escapeHtml(SALA_NOMBRE_JS[s.sala])}</span>
            <span class="cpc-time">${escapeHtml(fmtRange(s.inicio, s.fin))}</span>
          </header>
          <a class="cpc-title-link" href="/sesion/${escapeHtml(s.id)}">
            <h3 class="cpc-title">${escapeHtml(s.titulo)}</h3>
          </a>
          ${speakers ? `<p class="cpc-speakers">${escapeHtml(speakers)}</p>` : ''}
          <button class="cpc-keep" data-keep="${escapeHtml(s.id)}" data-drop="__OTHER__:${escapeHtml(otherId)}" type="button">
            Me quedo con esta →
          </button>
        </article>
      `;
    }

    function timeToMin(iso) {
      const time = iso.split('T')[1];
      const [h, m] = time.split(':').map(Number);
      return h * 60 + m;
    }

    function renderMiniCalendar(list) {
      const section = document.getElementById('calendar-section');
      const grid = document.getElementById('mini-calendar');
      if (!section || !grid) return;

      if (list.length === 0) {
        section.hidden = true;
        return;
      }
      section.hidden = false;

      const PX_PER_MIN = 2;
      const starts = list.map((s) => timeToMin(s.inicio));
      const ends = list.map((s) => timeToMin(s.fin));
      const minT = Math.floor(Math.min(...starts) / 60) * 60;
      const maxT = Math.ceil(Math.max(...ends) / 60) * 60;
      const height = (maxT - minT) * PX_PER_MIN;

      const pairs = findConflictPairs(list);
      const inConflict = new Set();
      for (const [a, b] of pairs) {
        inConflict.add(a.id);
        inConflict.add(b.id);
      }

      const hours = [];
      for (let h = minT; h <= maxT; h += 60) hours.push(h);

      const ticksHtml = hours
        .map((h, i) => {
          const top = (h - minT) * PX_PER_MIN;
          const label = `${String(Math.floor(h / 60)).padStart(2, '0')}:00`;
          const cls =
            i === 0 ? 'mc-tick mc-tick-first' : i === hours.length - 1 ? 'mc-tick mc-tick-last' : 'mc-tick';
          return `<span class="${cls}" style="top:${top}px;">${label}</span>`;
        })
        .join('');

      const colsHtml = ['pacifico', 'atlantico-b', 'atlantico-c']
        .map((sala) => {
          const slots = list.filter((s) => s.sala === sala);
          const slotsHtml = slots
            .map((s) => {
              const top = (timeToMin(s.inicio) - minT) * PX_PER_MIN;
              const slotH = Math.max(30, (timeToMin(s.fin) - timeToMin(s.inicio)) * PX_PER_MIN);
              const confCls = inConflict.has(s.id) ? ' is-conflict' : '';
              return `
                <a class="mc-slot sala-${sala}${confCls}"
                   href="/sesion/${escapeHtml(s.id)}"
                   style="top:${top}px;height:${slotH}px;"
                   aria-label="${escapeHtml(s.titulo)}, ${escapeHtml(SALA_NOMBRE_JS[sala])}, ${escapeHtml(s.inicio.slice(11, 16))} a ${escapeHtml(s.fin.slice(11, 16))}">
                  <span class="mc-slot-time">${escapeHtml(s.inicio.slice(11, 16))}</span>
                  <span class="mc-slot-title">${escapeHtml(s.titulo)}</span>
                </a>
              `;
            })
            .join('');
          return `<div class="mc-col">${slotsHtml}</div>`;
        })
        .join('');

      grid.innerHTML = `
        <div class="mc-cols-head" aria-hidden="true">
          <div></div>
          <div class="mc-sh sala-pacifico"><span class="mc-dot"></span>Pacífico</div>
          <div class="mc-sh sala-atlantico-b"><span class="mc-dot"></span>Atl B</div>
          <div class="mc-sh sala-atlantico-c"><span class="mc-dot"></span>Atl C</div>
        </div>
        <div class="mc-grid" style="height:${height}px;">
          <div class="mc-time-col">${ticksHtml}</div>
          ${colsHtml}
        </div>
      `;
    }

    function renderEmpty(ids) {
      const empty = document.getElementById('empty-state');
      const actions = document.getElementById('actions-bar');
      if (!empty || !actions) return;
      const isEmpty = ids.length === 0;
      empty.hidden = !isEmpty;
      actions.hidden = isEmpty;
    }

    function renderAll(ids) {
      const list = favSesiones(ids);
      const pairs = findConflictPairs(list);
      renderStats(list, pairs);
      renderConflictSection(pairs);
      renderMiniCalendar(list);
      renderEmpty(ids);
    }

    function setupImportPrompt() {
      const queryFavs = getQueryFavorites();
      if (!queryFavs || queryFavs.length === 0) {
        renderAll(getStored());
        return;
      }

      const stored = getStored();
      if (stored.length === 0) {
        setStored(queryFavs);
        const url = new URL(window.location.href);
        url.searchParams.delete('s');
        window.history.replaceState({}, '', url.toString());
        renderAll(queryFavs);
        return;
      }

      const prompt = document.getElementById('import-prompt');
      const sub = document.getElementById('prompt-sub');
      if (!prompt || !sub) {
        renderAll(stored);
        return;
      }

      sub.textContent = `Tenés ${stored.length} sesiones guardadas. La compartida tiene ${queryFavs.length}.`;
      prompt.hidden = false;

      prompt.querySelectorAll('[data-action]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const action = btn.dataset.action;
          let next = stored;
          if (action === 'replace') next = queryFavs;
          else if (action === 'merge') next = Array.from(new Set([...stored, ...queryFavs]));
          if (action !== 'cancel') setStored(next);
          prompt.hidden = true;
          const url = new URL(window.location.href);
          url.searchParams.delete('s');
          window.history.replaceState({}, '', url.toString());
          renderAll(getStored());
        });
      });

      renderAll(stored);
    }

    function setupShare() {
      const btn = document.getElementById('share-btn');
      const status = document.getElementById('actions-status');
      if (!btn || !status) return;

      btn.addEventListener('click', async () => {
        const ids = getStored();
        const url = `${window.location.origin}/mi-dia?s=${encodeURIComponent(ids.join(','))}`;
        const count = ids.length;
        const text = `Mi agenda para AIFI26 (${count} ${count === 1 ? 'charla' : 'charlas'}) · 21 may, Hilton BA`;

        if (navigator.share) {
          try {
            await navigator.share({ title: 'AIFI26', text, url });
            status.textContent = '✓ compartido';
            setTimeout(() => (status.textContent = ''), 3000);
            return;
          } catch (err) {
            if (err && err.name === 'AbortError') {
              status.textContent = '';
              return;
            }
          }
        }

        try {
          await navigator.clipboard.writeText(url);
          status.textContent = '✓ link copiado al portapapeles';
          setTimeout(() => (status.textContent = ''), 3000);
        } catch {
          status.textContent = url;
        }
      });
    }

    function escapeIcs(s) {
      return String(s).replace(/\\/g, '\\\\').replace(/;/g, '\\;').replace(/,/g, '\\,').replace(/\n/g, '\\n');
    }

    function toIcsLocal(iso) {
      const [date, time] = iso.replace('-03:00', '').split('T');
      return `${date.replace(/-/g, '')}T${time.replace(/:/g, '')}`;
    }

    function buildAndDownloadIcs(ids) {
      const speakersById = new Map(speakersData.map((s) => [s.id, s]));
      const my = sesionesData.filter((s) => ids.includes(s.id));
      const stamp = new Date().toISOString().replace(/[-:]/g, '').replace(/\.\d+/, '');
      const events = my.map((s) => {
        const desc = [
          s.descripcion ?? '',
          '',
          'Speakers:',
          ...s.speakers.map((id) => speakersById.get(id)).filter(Boolean).map((sp) => `· ${sp.nombre} — ${sp.rol}`),
          s.moderador && speakersById.get(s.moderador)
            ? `Moderador: ${speakersById.get(s.moderador).nombre} — ${speakersById.get(s.moderador).rol}`
            : '',
        ].filter(Boolean).join('\n');
        return [
          'BEGIN:VEVENT',
          `UID:${s.id}@aifi26`,
          `DTSTAMP:${stamp}`,
          `DTSTART;TZID=America/Argentina/Buenos_Aires:${toIcsLocal(s.inicio)}`,
          `DTEND;TZID=America/Argentina/Buenos_Aires:${toIcsLocal(s.fin)}`,
          `SUMMARY:${escapeIcs(s.titulo)}`,
          `LOCATION:${escapeIcs('Salón ' + SALA_NOMBRE_JS[s.sala] + ' · Hotel Hilton Buenos Aires')}`,
          `DESCRIPTION:${escapeIcs(desc)}`,
          'END:VEVENT',
        ].join('\r\n');
      }).join('\r\n');

      const body = [
        'BEGIN:VCALENDAR',
        'VERSION:2.0',
        'PRODID:-//AIFI26//cronograma no oficial//ES',
        'CALSCALE:GREGORIAN',
        'METHOD:PUBLISH',
        events,
        'END:VCALENDAR',
      ].join('\r\n');

      const blob = new Blob([body], { type: 'text/calendar' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'aifi26-mi-dia.ics';
      document.body.appendChild(a);
      a.click();
      a.remove();
      setTimeout(() => URL.revokeObjectURL(url), 1000);
    }

    function setupIcs() {
      const btn = document.getElementById('ics-btn');
      const status = document.getElementById('actions-status');
      if (!btn || !status) return;
      btn.addEventListener('click', () => {
        const ids = getStored();
        if (ids.length === 0) return;
        buildAndDownloadIcs(ids);
        status.textContent = '✓ agenda descargada';
        setTimeout(() => (status.textContent = ''), 3000);
      });
    }

    function openClearModal() {
      const modal = document.getElementById('clear-modal');
      const msg = document.getElementById('clear-msg');
      const ids = getStored();
      if (!modal || ids.length === 0) return;
      if (msg) {
        msg.textContent = `Vas a perder ${ids.length} ${ids.length === 1 ? 'sesión guardada' : 'sesiones guardadas'}.`;
      }
      modal.hidden = false;
      document.body.style.overflow = 'hidden';
      modal.querySelector('[data-clear-confirm]').focus();
    }

    function closeClearModal() {
      const modal = document.getElementById('clear-modal');
      if (!modal) return;
      modal.hidden = true;
      document.body.style.overflow = '';
      document.getElementById('clear-btn')?.focus();
    }

    function setupClear() {
      const btn = document.getElementById('clear-btn');
      const modal = document.getElementById('clear-modal');
      if (!btn || !modal) return;

      btn.addEventListener('click', () => openClearModal());

      modal.querySelectorAll('[data-clear-cancel]').forEach((el) => {
        el.addEventListener('click', closeClearModal);
      });

      modal.querySelector('[data-clear-confirm]')?.addEventListener('click', () => {
        setStored([]);
        renderAll([]);
        closeClearModal();
        const status = document.getElementById('actions-status');
        if (status) {
          status.textContent = '✓ tu día está vacío';
          setTimeout(() => (status.textContent = ''), 3000);
        }
      });

      document.addEventListener('keydown', (e) => {
        if (e.key !== 'Escape') return;
        if (!modal.hidden) closeClearModal();
      });
    }

    function init() {
      setupImportPrompt();
      setupShare();
      setupIcs();
      setupClear();
    }

    document.addEventListener('astro:page-load', init);
    init();
  </script>
</Layout>

<style>
  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--s-4);
  }

  /* IMPORT PROMPT */
  .import-prompt {
    background: rgba(15, 179, 252, 0.08);
    border-bottom: 1px solid var(--cyan);
    padding: var(--s-4) 0;
  }

  .prompt-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--t-md);
    color: var(--fg);
    margin: 0 0 var(--s-2);
  }

  .prompt-sub {
    font-family: var(--font-body);
    font-size: var(--t-sm);
    color: var(--fg-soft);
    margin: 0 0 var(--s-3);
  }

  .prompt-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
  }

  /* HERO */
  .hero {
    padding: var(--s-5) 0 var(--s-4);
    border-bottom: 1px solid var(--hair);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 var(--s-2);
  }

  .title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--t-3xl);
    letter-spacing: -0.035em;
    line-height: 0.95;
    margin: 0 0 var(--s-5);
    color: var(--fg);
  }

  .stats {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--s-3);
  }

