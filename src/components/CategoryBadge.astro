---
import type { CategoriaSlug } from '../types';
import categoriasData from '../data/categorias.json';

interface Props {
  slug: CategoriaSlug;
}

const { slug } = Astro.props;
const cat = categoriasData.find((c) => c.slug === slug);
const nombre = cat?.nombre ?? slug;
---

<a class="cat-badge" href={`/categoria/${slug}`} data-cat={slug}>
  {nombre}
</a>

<style>
  .cat-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--fg-muted);
    background: var(--bg-card-2);
    padding: 3px var(--s-2);
    border-radius: var(--r-sm);
    text-decoration: none;
    letter-spacing: 0;
    line-height: 1.3;
    border: 1px solid var(--hair);
    transition: color var(--m-fast) var(--m-ease), border-color var(--m-fast) var(--m-ease);
  }

  .cat-badge:hover {
    color: var(--fg);
    border-color: var(--hair-bright);
  }
</style>
